datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String     @id
  githubId       Int        @unique
  username       String     @unique
  avatarUrl      String
  name           String?
  bio            String?
  accessToken    String?    // Stored from Supabase provider token
  hustleScore    Int        @default(0)
  mode           Mode       @default(PUBLIC)
  grantedScopes    String[]   // GitHub OAuth scopes
  lastScoredAt   DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  snapshots      Snapshot[]
}

model Snapshot {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  
  score          Int
  nairaValue     Int
  breakdown      Json
  stats          Json
  
  createdAt      DateTime @default(now())
  
  @@index([userId, createdAt])
}

enum Mode {
  PUBLIC
  PRIVATE
}
